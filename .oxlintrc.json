{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "oxc",
    "vue"
  ],
  "env": {
    "browser": true,
    "jquery": true,
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/dist-ssr/**",
    "**/coverage/**",
    "**/storybook-static/**",
    "**/node_modules/**",
  ],
}