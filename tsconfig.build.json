{
    "extends": [
        "./tsconfig.json",
        "@vue/tsconfig/tsconfig.lib.json"
    ],
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "src/**/*.stories.*",
        "src/**/*.test.*",
        "src/**/__tests__"
    ]
}