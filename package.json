{
  "name": "@j1nn0/vue-modal-dialog",
  "version": "0.13.4",
  "description": "A reusable Vue 3 modal dialog component with focus trap and ARIA support",
  "keywords": [
    "vue",
    "dialog",
    "modal",
    "modal-dialog",
    "focus-trap",
    "accessible"
  ],
  "author": "j1nn0 <j1nn0.github@gmail.com>",
  "license": "MIT",
  "main": "dist/vue-modal-dialog.umd.js",
  "module": "dist/vue-modal-dialog.es.js",
  "types": "dist/index.d.ts",
  "style": "dist/vue-modal-dialog.css",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.34.4",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit -p tsconfig.build.json && vite build",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui --coverage",
    "coverage": "vitest run --coverage",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "size": "size-limit",
    "release": "release-it",
    "upgrade-interactive": "pnpm update --interactive",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j1nn0/vue-modal-dialog.git"
  },
  "bugs": {
    "url": "https://github.com/j1nn0/vue-modal-dialog/issues"
  },
  "homepage": "https://github.com/j1nn0/vue-modal-dialog#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vitest/ui": "^4.1.9",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "autoprefixer": "^10.5.1",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "^1.71.0",
    "eslint-plugin-vue": "^10.9.2",
    "focus-trap": "^8.2.2",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.15",
    "release-it": "^20.2.0",
    "sass-embedded": "^1.100.0",
    "storybook": "^10.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-dts": "^5.0.2",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  },
  "peerDependencies": {
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "focus-trap": "^8.2.2",
    "vue": "^3.5.38"
  },
  "pnpm": {
    "overrides": {
      "glob": "^13.0.6"
    }
  }
}
