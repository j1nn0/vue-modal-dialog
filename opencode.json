{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "enabled": true
        },
        "serena": {
            "type": "local",
            "enabled": true,
            "command": [
                "uvx",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--project-from-cwd",
                "--context",
                "ide"
            ]
        }
    },
    "agent": {
        "ask": {
            "mode": "primary",
            "permission": {
                "*": "deny"
            },
            "tools": {
                "*": false
            },
            "prompt": " "
        }
    }
}